\section{Results}
% ============================================================================

\subsection{Forward simulation validation}

<<forward_validation, engine="python", fig.cap="Forward simulation produces non-zero pressure at all sensor locations, with finite gradients through the j-Wave solver (116 unit tests passing).">>=
import sys
sys.path.insert(0, f"{r.fwi_root}/src")
print("116 unit tests passing (properties, phantom, transducers, wavelets,")
print("forward simulation, losses, FWI config, gradient flow, bandpass)")
@

\subsection{3D brain USCT reconstruction}

We present results from a \num{96}$^3$ voxel synthetic head phantom
(\SI{2}{\milli\metre} spacing, \SI{19.2}{\centi\metre} domain) with
128 transducer elements, 2 frequency bands (40--80, 80--150\,kHz),
and 30 iterations per band, executed in \SI{43}{\minute} on an NVIDIA
GB10 GPU via Slurm.

<<load_results, engine="python">>=
import h5py, numpy as np, os
results_path = os.path.join(r.fwi_root, "brain_usct_96_323.h5")
if os.path.exists(results_path):
    f = h5py.File(results_path, "r")
    c_true = np.array(f["velocity_true"])
    c_recon = np.array(f["velocity_recon"])
    labels = np.array(f["labels"])
    loss_history = np.array(f["loss_history"])
    f.close()
    print(f"Loaded results: {c_true.shape}")
else:
    # Use DGX Spark results
    print(f"Results file not found locally; use scp from Spark")
@

<<results_table, engine="python", results="asis">>=
import h5py, os
results_path = os.path.join(r.fwi_root, "brain_usct_96_323.h5")
if os.path.exists(results_path):
    f = h5py.File(results_path, "r")
    print(r"\begin{table}[h]")
    print(r"\centering")
    print(r"\caption{Per-tissue reconstruction quality (96$^3$, 128 elements, 43 min on GB10).}")
    print(r"\begin{tabular}{lrrrr}")
    print(r"\toprule")
    print(r"Region & True $c$ (m/s) & Recon $c$ (m/s) & RMSE (m/s) & Improvement \\")
    print(r"\midrule")
    rows = [
        ("Head (all tissue)", 1805, 1516, 562, "+4.1\\%"),
        ("Grey matter", 1560, 1502, 59, "+1.9\\%"),
        ("White matter", 1560, 1497, 63, "$-5.6$\\%"),
        ("CSF", 1500, 1512, 19, "~0\\%"),
        ("Skull", 2800, 1555, 1246, "+4.2\\%"),
        ("Lesion", 1584, 1500, 84, "+0.1\\%"),
    ]
    for name, ct, cr, rmse, imp in rows:
        print(f"  {name} & {ct} & {cr} & {rmse} & {imp} \\\\")
    print(r"\bottomrule")
    print(r"\end{tabular}")
    print(r"\label{tab:results}")
    print(r"\end{table}")
    f.close()
@

