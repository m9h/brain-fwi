{
    "name": "OpenLIFU Focused Ultrasound Simulation",
    "description": "Simulate focused ultrasound (LIFU) using the OpenLIFU-python pipeline and j-Wave. Supports individualized head models from SimNIBS.",
    "tag": ["ultrasound", "LIFU", "neuromodulation", "j-Wave", "OpenLIFU"],
    "author": "Openwater / Morgan Hough",
    "maintainer": "Morgan Hough",
    "github": "https://github.com/OpenwaterHealth/openlifu-python",
    "inputs": [
        {
            "id": "m2m",
            "type": "neuro/m2m",
            "desc": "SimNIBS m2m directory"
        },
        {
            "id": "transducer",
            "type": "raw",
            "desc": "Transducer configuration (JSON)"
        }
    ],
    "outputs": [
        {
            "id": "pressure",
            "type": "neuro/mask",
            "desc": "Peak pressure field (NIfTI)"
        },
        {
            "id": "metrics",
            "type": "raw",
            "desc": "Focal spot metrics (JSON)"
        }
    ],
    "config": {
        "target_x": {
            "type": "number",
            "default": 0,
            "desc": "Focal target X (relative to center, mm)"
        },
        "target_y": {
            "type": "number",
            "default": 0,
            "desc": "Focal target Y (relative to center, mm)"
        },
        "target_z": {
            "type": "number",
            "default": 0,
            "desc": "Focal target Z (relative to center, mm)"
        },
        "frequency": {
            "type": "number",
            "default": 500000,
            "desc": "Frequency in Hz"
        }
    }
}
